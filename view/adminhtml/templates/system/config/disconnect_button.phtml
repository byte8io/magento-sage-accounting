?>
<?= $block->getButtonHtml() ?>
<script>
    require(['jquery', 'Magento_Ui/js/modal/confirm', 'mage/translate'], function ($, confirmation) {
        $('#byte8_sage_disconnect_button').on('click', function (e) {
            e.preventDefault();
            if ($(this).attr('disabled')) {
                return false;
            }
            confirmation({
                title: $.mage.__('Disconnect from Sage?'),
                content: $.mage.__('This clears the local tenant credentials and tells Byte8 Ledger to revoke the binding. You will need to reconnect before the next sync runs.'),
                actions: {
                    confirm: function () {
                        var form = $('<form>', {
                            method: 'post',
                            action: <?= /* @noEscape */ json_encode($block->getDisconnectUrl()) ?>
                        }).append(
                            $('<input>', {type: 'hidden', name: 'form_key', value: <?= /* @noEscape */ json_encode($block->getFormKey()) ?>})
                        );
                        $('body').append(form);
                        form.submit();
                    }
                }
            });
            return false;
        });
    });
</script>
